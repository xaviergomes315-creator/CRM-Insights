# ── Frontend (crm-dashboard) ──────────────────────────────────────────────────
# Supabase project URL (used by the browser client)
VITE_SUPABASE_URL=
# Supabase anonymous/public key (used by the browser client)
VITE_SUPABASE_ANON_KEY=

# ── API Server ────────────────────────────────────────────────────────────────
# Supabase service-role key (bypasses RLS — server-side only, never expose to browser)
SUPABASE_SERVICE_ROLE_KEY=
# Secret used to sign server-side sessions
SESSION_SECRET=
# PostgreSQL connection string
DATABASE_URL=
# Logging verbosity: error | warn | info | debug (optional, defaults to info)
LOG_LEVEL=
