# =============================================================================
# CRM Pro — Required Environment Variables
# =============================================================================
# Copy this file to .env for local development, or add each as a Replit Secret.
# Variables marked (REQUIRED) will cause the app to fail or features to be
# unavailable if missing. Variables marked (OPTIONAL) have safe defaults.
# =============================================================================


# ── Supabase (REQUIRED for login and all CRM data) ───────────────────────────
# Your Supabase project URL.
# Source: Supabase dashboard → Project Settings → API → Project URL
VITE_SUPABASE_URL=

# Supabase anonymous/public key — safe to expose to the browser.
# Source: Supabase dashboard → Project Settings → API → anon / public
VITE_SUPABASE_ANON_KEY=

# Supabase service-role key — bypasses RLS. SERVER-SIDE ONLY, never expose to browser.
# Source: Supabase dashboard → Project Settings → API → service_role / secret
SUPABASE_SERVICE_ROLE_KEY=


# ── PostgreSQL (REQUIRED for the API server and Drizzle ORM) ─────────────────
# Full PostgreSQL connection string.
# Source: Supabase dashboard → Project Settings → Database → Connection string (URI mode)
#         (use the "Session mode" pooler URL for serverless, or the direct URL for long-lived servers)
# NOTE: On Replit the local PostgreSQL is already provisioned — DATABASE_URL is
#       set automatically. Only override this if connecting to an external DB.
DATABASE_URL=


# ── Session (REQUIRED for server-side sessions) ──────────────────────────────
# A long random string used to sign server-side session cookies.
# Source: generate with: openssl rand -base64 64
# NOTE: Already set as a Replit Secret in this workspace.
SESSION_SECRET=


# ── WhatsApp / Meta Cloud API (REQUIRED only if using WhatsApp features) ─────

# Permanent access token from your Meta System User.
# Source: Meta Business Suite → Business Settings → System Users → Generate Token
WHATSAPP_ACCESS_TOKEN=

# The phone number ID of your WhatsApp Business number.
# Source: Meta for Developers → your App → WhatsApp → API Setup → Phone Number ID
WHATSAPP_PHONE_NUMBER_ID=

# WhatsApp Business Account ID (WABA ID).
# Source: Meta for Developers → your App → WhatsApp → API Setup → WhatsApp Business Account ID
WHATSAPP_WABA_ID=

# Webhook verify token — a string YOU choose and set in BOTH this secret AND
# the Meta App dashboard (App → WhatsApp → Configuration → Webhook → Verify Token).
# Source: generate any random string, e.g.: openssl rand -hex 20
WHATSAPP_VERIFY_TOKEN=

# Meta App Secret — used to verify HMAC-SHA256 webhook signatures.
# Recommended in production; omit to skip signature validation in dev.
# Source: Meta for Developers → your App → Settings → Basic → App Secret
WHATSAPP_APP_SECRET=

# UUID of the company row in your database that owns this WhatsApp number.
# Required for the webhook to associate incoming messages with the right company.
# Source: your Supabase database → public.companies table → id column
WHATSAPP_COMPANY_ID=

# UUID of a valid user in auth.users (Supabase Auth) used as `created_by`
# for conversations created by the webhook (satisfies the NOT NULL foreign key).
# Source: your Supabase dashboard → Authentication → Users → copy the User UID
WHATSAPP_SYSTEM_USER_ID=


# ── SMTP / Email (REQUIRED only if using proposal email sending) ──────────────

# SMTP server hostname.
# Source: your email provider — e.g. smtp.gmail.com, smtp.sendgrid.net
SMTP_HOST=

# SMTP port. Common values: 587 (STARTTLS), 465 (SSL), 25.
SMTP_PORT=587

# SMTP username (usually your email address or API username).
SMTP_USER=

# SMTP password or app password.
# For Gmail: generate an App Password at myaccount.google.com/apppasswords
SMTP_PASS=

# (OPTIONAL) From address shown on outgoing emails. Defaults to SMTP_USER if omitted.
SMTP_FROM=


# ── OpenAI (OPTIONAL — enables AI message suggestions) ───────────────────────
# Source: platform.openai.com → API Keys
OPENAI_API_KEY=


# ── Server config (OPTIONAL) ─────────────────────────────────────────────────

# Logging level for the API server. Values: error | warn | info | debug
# Defaults to "info" if not set.
LOG_LEVEL=info

# Comma-separated list of allowed CORS origins in production.
# Example: https://mycrm.com,https://www.mycrm.com
# Defaults to permissive (allow all) in development when not set.
CORS_ORIGIN=


# ── Migration tool only (supabase/run_migrations.mjs) ────────────────────────
# Only needed when running database migrations via the Supabase CLI.
# Source: app.supabase.com → Account → Access Tokens
SUPABASE_ACCESS_TOKEN=
